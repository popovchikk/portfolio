---
interface Props {
  title: string;
  description: string;
  videoUrl?: string;
  task?: string;
  result?: string;
}
const { title, description, videoUrl, task, result } = Astro.props;
---

<div class="bg-secondary rounded-xl overflow-hidden border border-white/5 hover:border-accent/50 transition-all duration-300 group flex flex-col h-full">
  
  <div class="relative w-full bg-black overflow-hidden" style="aspect-ratio: 9/16; min-height: 450px;">
    {videoUrl ? (
      <>
        <video 
          src={videoUrl} 
          class="w-full h-full video-element"
          preload="metadata"
          playsinline
          oncontextmenu="return false;"
        >
          Ваш браузер не поддерживает видео.
        </video>
        
        <div class="video-overlay absolute inset-0 flex items-center justify-center z-10">
          <button 
            class="play-button w-20 h-20 rounded-full bg-accent hover:bg-accent-light flex items-center justify-center transform hover:scale-110 transition-all duration-300 shadow-2xl"
            aria-label="Play"
          >
            <svg class="w-10 h-10 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
        </div>
      </>
    ) : (
      <div class="w-full h-full flex items-center justify-center text-text-muted bg-white/5">
        <span>Video Placeholder</span>
      </div>
    )}
  </div>

  <div class="p-6 md:p-8 flex-1 flex flex-col">
    <h3 class="text-2xl font-bold text-white mb-3">{title}</h3>
    <p class="text-text-secondary text-base mb-6 flex-1 leading-relaxed">{description}</p>

    <div class="grid grid-cols-2 gap-6 border-t border-white/10 pt-6">
      {task && (
        <div>
          <span class="text-accent text-xs font-bold uppercase tracking-widest block mb-2">Задача</span>
          <p class="text-sm text-text-muted leading-snug">{task}</p>
        </div>
      )}
      {result && (
        <div>
          <span class="text-accent text-xs font-bold uppercase tracking-widest block mb-2">Результат</span>
          <p class="text-sm text-text-muted leading-snug">{result}</p>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .video-element {
    object-fit: contain;
  }
  
  .video-element:-webkit-full-screen {
    object-fit: contain;
    width: 100%;
    height: 100%;
  }
  
  .video-element:-moz-full-screen {
    object-fit: contain;
    width: 100%;
    height: 100%;
  }
  
  .video-element:fullscreen {
    object-fit: contain;
    width: 100%;
    height: 100%;
  }
</style>