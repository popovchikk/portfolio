---
import Section from '../ui/Section.astro';
import VideoCard from '../ui/VideoCard.astro';

const cases = [
  {
    title: "Базовый монтаж",
    description: "Классический стиль. Говорящая голова, чистый звук, динамичная склейка.",
    videoUrl: "/videos/Basic.mp4",
    task: "Сделать видео экспертным и чистым",
    result: "Четкая подача материала, ничего лишнего"
  },
  {
    title: "Стандарт (+Весь Базовый)",
    description: "Включает всё из Базового монтажа + переходы, B-roll, визуальные акценты и динамику.",
    videoUrl: "/videos/Standart.mp4",
    task: "Удержать внимание зрителя",
    result: "Retention выше, зрители смотрят до конца"
  },
  {
    title: "Стандарт 2",
    description: "Ещё один пример работы в стиле Standard с эффектами.",
    videoUrl: "/videos/Standart2.mp4",
    task: "Показать универсальность формата",
    result: "Подходит для любых ниш"
  },
  {
    title: "HARD / Motion 1",
    description: "Максимальная упаковка. Моушн-дизайн, сложная анимация.",
    videoUrl: "/videos/Hard1.mp4",
    task: "Создать 'вау-эффект' и премиальный вид",
    result: "Контент уровня топовых блогеров"
  },
  {
    title: "HARD / Motion 2",
    description: "Продвинутый моушн с динамичной графикой и звуковым дизайном.",
    videoUrl: "/videos/Hard2.mp4",
    task: "Продемонстрировать сложные техники",
    result: "Уникальный визуальный стиль"
  }
];
---

<Section id="cases" class="bg-primary">
  <div class="mb-16 text-center animate-on-scroll">
    <h2 class="text-3xl md:text-5xl font-bold mb-4">
      Примеры <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-rose-600">работ</span>
    </h2>
    <p class="text-text-secondary text-lg max-w-2xl mx-auto">
      Я работаю в разных стилях. От строгой говорящей головы до сложной моушн-упаковки.
    </p>
  </div>

  <div class="flex flex-wrap justify-center gap-8 md:gap-10 w-full max-w-[1300px] mx-auto px-4">
    {cases.map((caseItem, index) => (
      <div class={`w-full sm:w-[46%] lg:w-[30%] animate-on-scroll delay-${(index + 1) * 100}`}>
        <VideoCard 
          title={caseItem.title}
          description={caseItem.description}
          videoUrl={caseItem.videoUrl}
          task={caseItem.task}
          result={caseItem.result}
        />
      </div>
    ))}
  </div>
</Section>