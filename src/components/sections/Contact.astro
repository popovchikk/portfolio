---
import Section from '../ui/Section.astro';
---

<Section id="contact" class="bg-primary">
  <div class="max-w-5xl mx-auto text-center px-4">
    
    <!-- Заголовок -->
    <div class="mb-12 animate-on-scroll">
      <h2 class="text-4xl md:text-6xl font-bold mb-6">
        Давай <span class="text-accent">обсудим</span> проект
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Напиши мне, расскажи о своей задаче. Я отвечу в течение 24 часов.
      </p>
    </div>

    <!-- Кнопка Telegram -->
    <div class="mb-16 animate-on-scroll delay-100">
      <a 
        href="https://t.me/aur1lx" 
        target="_blank"
        class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent/90 text-white font-bold py-4 px-10 rounded-xl text-lg transition-all duration-300 transform hover:scale-105 shadow-lg shadow-accent/30"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        Написать в Telegram
      </a>
    </div>

    <!-- Карточки контактов -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16 animate-on-scroll delay-200">
      
      <!-- Telegram Card -->
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 hover:border-accent/50 transition-all duration-300 group flex flex-col items-center">
        <div class="w-14 h-14 rounded-xl bg-accent flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-accent/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        </div>
        <h3 class="text-white font-bold text-lg mb-2">TELEGRAM</h3>
        <a href="https://t.me/aur1lx" target="_blank" class="text-text-secondary hover:text-accent transition-colors text-lg">@aur1lx</a>
      </div>

      <!-- Instagram Card -->
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 hover:border-accent/50 transition-all duration-300 group flex flex-col items-center">
        <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-purple-500/20">
           <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </div>
        <h3 class="text-white font-bold text-lg mb-2">INSTAGRAM</h3>
        <a href="https://instagram.com/aur1lx" target="_blank" class="text-text-secondary hover:text-accent transition-colors text-lg">aur1lx</a>
      </div>

      <!-- Email Card (ИСПРАВЛЕННОЕ) -->
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 hover:border-accent/50 transition-all duration-300 group flex flex-col items-center">
        <div class="w-14 h-14 rounded-xl bg-accent flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-accent/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        </div>
        <h3 class="text-white font-bold text-lg mb-2">EMAIL</h3>
        <!-- 
           ИЗМЕНЕНИЯ:
           1. text-sm: Чуть уменьшили шрифт, чтобы влезало лучше.
           2. break-words: Позволяет переносить текст, но аккуратно (не рвет gmail.com посередине).
           3. text-center: Центрируем текст.
        -->
        <a 
          href="mailto:mainpopov887@gmail.com" 
          class="text-text-secondary hover:text-accent transition-colors text-sm break-words text-center w-full"
        >
          mainpopov887@gmail.com
        </a>
      </div>

    </div>

    <!-- Блок с информацией -->
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 text-left flex flex-col md:flex-row gap-6 items-start animate-on-scroll delay-300">
       <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center flex-shrink-0 text-accent">
         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
       </div>
       <div>
         <h4 class="text-white font-bold text-xl mb-3">Как со мной связаться?</h4>
         <p class="text-text-secondary leading-relaxed">
           Быстрее всего отвечаю в <strong class="text-white">Telegram</strong> — обычно в течение 2-4 часов в рабочее время. Если не ответил сразу — значит работаю над проектом, напишу как освобожусь. Email проверяю 1-2 раза в день.
         </p>
       </div>
    </div>

  </div>
</Section>