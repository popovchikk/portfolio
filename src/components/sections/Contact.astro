---
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
---

<Section id="contact" class="bg-gradient-to-b from-secondary to-primary">
  <div class="max-w-4xl mx-auto text-center animate-on-scroll">
    <h2 class="text-3xl md:text-5xl font-bold mb-6">
      Давай <span class="text-accent">обсудим</span> проект
    </h2>
    <p class="text-text-secondary text-lg mb-12">
      Напиши мне, расскажи о своей задаче. Я отвечу в течение 24 часов.
    </p>

    <!-- Кнопка Telegram -->
    <div class="mb-12">
      <Button href="https://t.me/aur1lx" variant="primary">
        Написать в Telegram
      </Button>
    </div>

    <!-- Контактная информация -->
    <div class="grid md:grid-cols-3 gap-6 max-w-3xl mx-auto">
      <!-- Telegram -->
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:border-accent/50 transition-all duration-300 group">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-gradient-to-br from-accent to-accent/70 flex items-center justify-center group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.446 1.394c-.14.18-.357.295-.6.295l.213-3.054 5.56-5.022c.242-.213-.054-.334-.373-.121l-6.869 4.326-2.96-.924c-.64-.203-.658-.64.135-.954l11.566-4.458c.538-.196 1.006.128.832.941z"/>
          </svg>
        </div>
        <p class="text-sm text-text-muted mb-2 uppercase tracking-wider font-semibold">Telegram</p>
        <a href="https://t.me/aur1lx" target="_blank" rel="noopener noreferrer" class="text-white font-medium hover:text-accent transition-colors">
          @aur1lx
        </a>
      </div>

      <!-- Instagram -->
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:border-accent/50 transition-all duration-300 group">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </div>
        <p class="text-sm text-text-muted mb-2 uppercase tracking-wider font-semibold">Instagram</p>
        <a href="https://instagram.com/aur1lx" target="_blank" rel="noopener noreferrer" class="text-white font-medium hover:text-accent transition-colors">
          aur1lx
        </a>
      </div>

      <!-- Email -->
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:border-accent/50 transition-all duration-300 group">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-gradient-to-br from-accent to-accent/70 flex items-center justify-center group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <p class="text-sm text-text-muted mb-2 uppercase tracking-wider font-semibold">Email</p>
        <a href="mailto:mainpopov887@gmail.com" class="text-white font-medium hover:text-accent transition-colors break-all">
          mainpopov887@gmail.com
        </a>
      </div>
    </div>

    <!-- Информационный блок -->
    <div class="mt-12 bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 max-w-2xl mx-auto">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="text-left">
          <h3 class="text-white font-semibold mb-2">Как со мной связаться?</h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            Быстрее всего отвечаю в <span class="text-white font-medium">Telegram</span> — обычно в течение 2-4 часов в рабочее время. 
            Если не ответил сразу — значит работаю над проектом, напишу как освобожусь. 
            Email проверяю 1-2 раза в день.
          </p>
        </div>
      </div>
    </div>
  </div>
</Section>