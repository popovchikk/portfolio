---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Cases from '../components/sections/Cases.astro';
import Process from '../components/sections/Process.astro';
import Contact from '../components/sections/Contact.astro';
import ScrollToTop from '../components/ui/ScrollToTop.astro';
---

<BaseLayout title="aur1lx | Никита — Монтаж видео">
  <Header />
  
  <main class="pt-20">
    <Hero />
    
    <!-- 🔹 МИНИМАЛИСТИЧНЫЙ РАЗДЕЛИТЕЛЬ -->
    <div class="w-full flex items-center justify-center py-8 md:py-12">
      <div class="w-16 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
      <div class="mx-3 w-1.5 h-1.5 rotate-45 bg-red-500/50"></div>
      <div class="w-16 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
    </div>
    <!-- 🔹 КОНЕЦ РАЗДЕЛИТЕЛЯ -->

    <About />
    <Cases />
    <Process />
    <Contact />
  </main>

  <Footer />
  <ScrollToTop />
</BaseLayout>